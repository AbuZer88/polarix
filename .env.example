# ── Required — server will refuse to start without these ─────────────────────

# Admin panel password (choose something strong)
ADMIN_KEY=change-me-before-deploying

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=generate-with-python-secrets-token-hex-32

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///canary.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@host:5432/polarix

# ── Environment tag (shown in /health response) ───────────────────────────────
ENVIRONMENT=development
# ENVIRONMENT=staging
# ENVIRONMENT=production

# ── CORS allow-list ───────────────────────────────────────────────────────────
# Comma-separated list of exact origins allowed to call the API from a browser.
# Required in production. If unset, only http://localhost / http://127.0.0.1 are
# allowed (development convenience). Browsers reject everything else.
# Example: CORS_ORIGINS=https://app.polarix.es,https://polarix.es
# CORS_ORIGINS=

# ── SQLite backup retention (only used when DATABASE_URL is sqlite://) ────────
# Daily backup task copies canary.db to backups/canary_YYYY-MM-DD.db
# Older backups are deleted. Set to 0 to disable. Default: 14 days.
# BACKUP_RETENTION_DAYS=14

# ── Sentry error tracking (optional) ──────────────────────────────────────────
# Free tier: https://sentry.io — copy your project DSN here. When empty, Sentry
# is not loaded at all. Production strongly recommended.
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# SENTRY_TRACES_RATE=0.1
# APP_VERSION=polarix@2.0.0

# ── Twilio (WhatsApp & SMS alerts) ───────────────────────────────────────────
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token

# WhatsApp sender (Twilio sandbox or approved number)
TWILIO_FROM=whatsapp:+14155238886

# SMS sender — your Twilio phone number (optional, only if using SMS)
# TWILIO_SMS_FROM=+14155238886

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Email alerts are FULLY BUILT — they activate automatically when SMTP_USER +
# SMTP_PASS are set. No code changes needed.
#
# How to get a Gmail App Password (required — your normal password won't work):
#   1. Go to your Google Account → Security → 2-Step Verification (must be ON)
#   2. Scroll down → App Passwords → Create → name it "Polarix"
#   3. Google shows a 16-character code (xxxx xxxx xxxx xxxx) — paste it as SMTP_PASS
#   4. You can revoke it any time from the same page without changing your main password
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=Polarix <your@gmail.com>

# Alternative providers (better deliverability for transactional email):
# Brevo (free 300 emails/day): SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587
# Resend (free 3000/month):    SMTP_HOST=smtp.resend.com       SMTP_PORT=587
# For other providers (Outlook, custom):
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587

# ── Teltonika HTTP data endpoint (FMB920/FMM920 in HTTP mode) ─────────────────
# When deploying on Railway (no raw TCP support), configure the device to use HTTP mode
# and set this token. The device sends X-Teltonika-Token: <value> in its POST header.
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
# Leave blank to disable token verification (not recommended in production).
TELTONIKA_HTTP_TOKEN=generate-with-python-secrets-token-hex-16

# ── Teltonika RMS (BLE sensor reassignment) ───────────────────────────────────
# Get your API token from: https://rms.teltonika-networks.com → Profile → API Tokens
# Leave blank to disable RMS pushes (reassignment still works locally, just no OTA config)
# TELTONIKA_RMS_TOKEN=your_rms_api_token_here

# ── Stripe (subscription billing) ────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for development, sk_live_... for production
# Leave blank to disable subscription management endpoints
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe Price IDs — create products/prices in Stripe dashboard first
# STRIPE_PRICE_ID_STARTER=price_xxxxxxxxxxxxx   # €29/month — 1 sensor
# STRIPE_PRICE_ID_GROWTH=price_xxxxxxxxxxxxx    # €79/month — up to 5 sensors
# STRIPE_PRICE_ID_FLEET=price_xxxxxxxxxxxxx     # €199/month — unlimited sensors
